# Copy this file to .env and fill in real values before running the service.

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/urlshortener
POSTGRES_USER=urluser
POSTGRES_PASSWORD=urlpass

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — MUST be changed to a strong random secret in production
SECRET_KEY=any-random-string-for-local-dev
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Alias generation
SHORT_CODE_LENGTH=7

# Rate limiting (slowapi format: "N/period")
RATE_LIMIT_LINKS_CREATE=20/minute
RATE_LIMIT_REDIRECT=200/minute

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
